# Leave blank to use deterministic mock mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

APP_ENV=development
LOG_LEVEL=INFO
RAG_TOP_K=5
RAG_MIN_SCORE=0.18
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# "hash" is fully offline. Use "sentence-transformers" for semantic embeddings;
# the first run may download EMBEDDING_MODEL.
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
